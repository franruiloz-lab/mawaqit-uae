---
import { cities } from '../data/cities';
import '../styles/global.css';
import { u } from '../utils/url';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  cityName?: string;
  cityId?: string;
  schema?: object | object[];
}

const { title, description, canonical, cityName, cityId, schema } = Astro.props;

// Single source of truth: update astro.config.mjs when switching to custom domain
const _site = import.meta.env.SITE.replace(/\/$/, '');       // https://franruiloz-lab.github.io
const _base = import.meta.env.BASE_URL.replace(/\/$/, '');   // /mawaqit-uae
const siteUrl = `${_site}${_base}`;                          // https://franruiloz-lab.github.io/mawaqit-uae
const canonicalUrl = canonical
  ? `${siteUrl}${canonical}`
  : `${siteUrl}${Astro.url.pathname}`;

const mainCities = cities.filter(c =>
  ['dubai','abu-dhabi','sharjah','ajman','al-ain','ras-al-khaimah','fujairah','umm-al-quwain'].includes(c.id)
);

const schemaJson = schema ? (Array.isArray(schema) ? schema : [schema]) : [];

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'مواقيت الصلاة في الإمارات',
  url: siteUrl,
  description: 'مواقيت الصلاة اليوم في جميع مدن الإمارات العربية المتحدة',
  inLanguage: 'ar',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: `${siteUrl}/?q={search_term_string}` },
    'query-input': 'required name=search_term_string',
  },
};

const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="ar" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="ar_AE" />
  <meta property="og:site_name" content="مواقيت الصلاة الإمارات" />
  <meta property="og:image" content={`${siteUrl}/og-image.svg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="مواقيت الصلاة في الإمارات" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}/og-image.svg`} />

  <!-- PWA -->
  <link rel="manifest" href={`${base}manifest.json`} />
  <meta name="theme-color" content="#097233" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="مواقيت الصلاة" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

  <!-- Arabic font -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Naskh+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  {schemaJson.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body class="bg-gray-50 text-gray-900 font-arabic antialiased">

  <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
  <header class="bg-primary-600 text-white shadow-lg sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between gap-3">

      <a href={u('')} class="flex items-center gap-2 font-bold text-lg leading-tight flex-shrink-0 min-h-0">
        <span class="text-2xl">🕌</span>
        <span>مواقيت الصلاة</span>
        <span class="text-primary-200 text-sm hidden sm:inline">الإمارات</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex gap-1 text-sm flex-wrap items-center">
        {mainCities.slice(0, 5).map(city => (
          <a
            href={u(city.id)}
            class={`px-2 py-1 rounded hover:bg-primary-700 transition-colors min-h-0 h-auto ${cityId === city.id ? 'bg-primary-800 font-semibold' : ''}`}
          >
            {city.nameAr}
          </a>
        ))}
        <a href={u('maghrib')} class={`px-2 py-1 rounded hover:bg-primary-700 transition-colors min-h-0 h-auto ${cityId === 'maghrib' ? 'bg-primary-800 font-semibold' : ''}`}>
          المغرب
        </a>
        <a href={u('ramadan')} class={`px-2 py-1 rounded hover:bg-primary-700 transition-colors min-h-0 h-auto ${cityId === 'ramadan' ? 'bg-primary-800 font-semibold' : ''}`}>
          رمضان
        </a>
      </nav>

      <!-- Mobile toggle button -->
      <button
        id="nav-toggle"
        type="button"
        class="md:hidden p-2 rounded-lg hover:bg-primary-700 transition-colors"
        aria-label="قائمة المدن"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-primary-700 border-t border-primary-500">
      <div class="max-w-5xl mx-auto px-4 py-3 grid grid-cols-3 gap-1 text-sm text-center">
        {cities.map(city => (
          <a
            href={u(city.id)}
            class={`py-2 px-1 rounded hover:bg-primary-600 transition-colors ${cityId === city.id ? 'bg-primary-800 font-semibold' : ''}`}
          >
            {city.nameAr}
          </a>
        ))}
      </div>
      <div class="max-w-5xl mx-auto px-4 pb-3 grid grid-cols-2 gap-1 text-sm text-center border-t border-primary-600 pt-2">
        <a href={u('maghrib')} class="py-2 rounded hover:bg-primary-600 transition-colors">🌇 أذان المغرب</a>
        <a href={u('ramadan')} class="py-2 rounded hover:bg-primary-600 transition-colors">🌙 رمضان</a>
      </div>
    </div>
  </header>

  <!-- ══ BREADCRUMB ═══════════════════════════════════════════════════════ -->
  {cityName && (
    <nav class="bg-white border-b border-gray-200 text-sm" aria-label="breadcrumb">
      <div class="max-w-5xl mx-auto px-4 py-2 flex gap-2 items-center text-gray-500">
        <a href={u('')} class="hover:text-primary-600 min-h-0 h-auto">الرئيسية</a>
        <span>›</span>
        <span class="text-gray-800 font-medium">{cityName}</span>
      </div>
    </nav>
  )}

  <!-- ══ MAIN ═════════════════════════════════════════════════════════════ -->
  <main>
    <slot />
  </main>

  <!-- ══ FOOTER ═══════════════════════════════════════════════════════════ -->
  <footer class="bg-primary-900 text-white mt-12">
    <div class="max-w-5xl mx-auto px-4 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">

        <div>
          <h3 class="font-bold text-primary-300 mb-3 text-sm">المدن الرئيسية</h3>
          <ul class="space-y-1 text-sm text-gray-300">
            {mainCities.map(city => (
              <li>
                <a href={u(city.id)} class="hover:text-white transition-colors">{city.nameAr}</a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="font-bold text-primary-300 mb-3 text-sm">مدن أخرى</h3>
          <ul class="space-y-1 text-sm text-gray-300">
            {cities.filter(c => !mainCities.find(m => m.id === c.id)).map(city => (
              <li>
                <a href={u(city.id)} class="hover:text-white transition-colors">{city.nameAr}</a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="font-bold text-primary-300 mb-3 text-sm">أوقات الصلاة</h3>
          <ul class="space-y-2 text-sm text-gray-300">
            <li><a href={u('maghrib')} class="hover:text-white transition-colors">موعد أذان المغرب</a></li>
            <li><a href={u('ramadan')} class="hover:text-white transition-colors">أوقات صلاة رمضان</a></li>
            <li><a href={u('dubai')} class="hover:text-white transition-colors">مواقيت الصلاة دبي</a></li>
            <li><a href={u('abu-dhabi')} class="hover:text-white transition-colors">مواقيت الصلاة أبوظبي</a></li>
          </ul>
        </div>

        <div>
          <h3 class="font-bold text-primary-300 mb-3 text-sm">معلومات</h3>
          <ul class="space-y-2 text-sm text-gray-300">
            <li><a href={u('about')} class="hover:text-white transition-colors">عن الموقع</a></li>
            <li><a href={u('privacy')} class="hover:text-white transition-colors">سياسة الخصوصية</a></li>
          </ul>
          <p class="text-xs text-gray-400 mt-4 leading-relaxed">
            طريقة الحساب:<br/>
            رابطة العالم الإسلامي<br/>
            UTC+4 (توقيت الإمارات)
          </p>
        </div>

      </div>
      <div class="border-t border-primary-700 pt-4 text-center text-sm text-gray-400 space-y-1">
        <p>© {new Date().getFullYear()} مواقيت الصلاة في الإمارات</p>
        <p class="text-xs">أوقات الصلاة محسوبة وفق طريقة رابطة العالم الإسلامي</p>
      </div>
    </div>
  </footer>

  <!-- Mobile menu script -->
  <script>
    (function () {
      const btn = document.getElementById('nav-toggle') as HTMLButtonElement | null;
      const menu = document.getElementById('mobile-menu') as HTMLElement | null;
      const iconOpen = document.getElementById('icon-open') as HTMLElement | null;
      const iconClose = document.getElementById('icon-close') as HTMLElement | null;

      if (!btn || !menu) return;

      btn.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden', isOpen);
        if (iconOpen) iconOpen.classList.toggle('hidden', !isOpen);
        if (iconClose) iconClose.classList.toggle('hidden', isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
          menu.classList.add('hidden');
          iconOpen?.classList.remove('hidden');
          iconClose?.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    })();
  </script>

</body>
</html>
