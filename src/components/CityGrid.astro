---
import { cities, mainCities } from '../data/cities';
import { u } from '../utils/url';

interface Props {
  currentCityId?: string;
  showAll?: boolean;
}
const { currentCityId, showAll = false } = Astro.props;
const displayCities = showAll ? cities : mainCities;
const extraCities = cities.filter(c => !mainCities.find(m => m.id === c.id));
---

<section>
  <h2 class="text-base font-bold text-gray-800 mb-3">مواقيت الصلاة في مدن الإمارات</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
    {displayCities.map(city => (
      <a
        href={u(city.id)}
        class={`flex flex-col items-center rounded-xl p-3 border-2 transition-all hover:shadow-md active:scale-95 ${
          city.id === currentCityId
            ? 'bg-primary-600 text-white border-primary-600 shadow-md'
            : 'bg-white border-gray-200 text-gray-700 hover:border-primary-300 hover:-translate-y-0.5'
        }`}
      >
        <div class="text-xl mb-1">🕌</div>
        <div class="font-semibold text-sm leading-tight text-center">{city.nameAr}</div>
        <div class={`text-xs mt-0.5 ${city.id === currentCityId ? 'text-primary-200' : 'text-gray-400'}`}>
          {city.nameEn}
        </div>
      </a>
    ))}
  </div>

  {!showAll && extraCities.length > 0 && (
    <details class="mt-3">
      <summary class="text-sm text-primary-600 cursor-pointer hover:underline list-none flex items-center gap-1 select-none">
        <span class="transition-transform open:rotate-90">▸</span>
        عرض المزيد ({extraCities.length} مدينة)
      </summary>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 mt-3">
        {extraCities.map(city => (
          <a
            href={u(city.id)}
            class="flex flex-col items-center rounded-xl p-3 border-2 border-gray-200 bg-white text-gray-700 hover:border-primary-300 hover:-translate-y-0.5 transition-all active:scale-95"
          >
            <div class="text-xl mb-1">🕌</div>
            <div class="font-semibold text-sm text-center">{city.nameAr}</div>
            <div class="text-xs text-gray-400">{city.nameEn}</div>
          </a>
        ))}
      </div>
    </details>
  )}
</section>
