---
import { cities, mainCities } from '../data/cities';
interface Props {
  currentCityId?: string;
  showAll?: boolean;
}
const { currentCityId, showAll = false } = Astro.props;
const displayCities = showAll ? cities : mainCities;
---

<section>
  <h2 class="text-lg font-bold text-gray-800 mb-4">
    مواقيت الصلاة في مدن الإمارات
  </h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
    {displayCities.map(city => (
      <a
        href={`/${city.id}`}
        class={`block rounded-xl p-3 text-center border-2 transition-all hover:shadow-md hover:-translate-y-0.5 ${
          city.id === currentCityId
            ? 'bg-primary-600 text-white border-primary-600 shadow-md'
            : 'bg-white border-gray-200 text-gray-700 hover:border-primary-300'
        }`}
      >
        <div class="text-xl mb-1">🕌</div>
        <div class="font-semibold text-sm leading-tight">{city.nameAr}</div>
        <div class={`text-xs mt-0.5 ${city.id === currentCityId ? 'text-primary-200' : 'text-gray-400'}`}>
          {city.nameEn}
        </div>
      </a>
    ))}
  </div>
  {!showAll && cities.length > mainCities.length && (
    <div class="mt-3 text-center">
      <details class="inline-block">
        <summary class="text-sm text-primary-600 cursor-pointer hover:underline">
          عرض جميع المدن ({cities.length} مدينة)
        </summary>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 mt-3">
          {cities.filter(c => !mainCities.includes(c)).map(city => (
            <a
              href={`/${city.id}`}
              class="block rounded-xl p-3 text-center border-2 border-gray-200 bg-white text-gray-700 hover:border-primary-300 transition-all"
            >
              <div class="text-xl mb-1">🕌</div>
              <div class="font-semibold text-sm">{city.nameAr}</div>
              <div class="text-xs text-gray-400">{city.nameEn}</div>
            </a>
          ))}
        </div>
      </details>
    </div>
  )}
</section>
