---
import { getMonthSchedule, arabicMonths } from '../utils/prayer';

interface Props {
  lat: number;
  lng: number;
  cityNameAr: string;
}
const { lat, lng, cityNameAr } = Astro.props;

const now = new Date();
const year = now.getFullYear();
const month = now.getMonth() + 1;
const schedule = getMonthSchedule(lat, lng, year, month);
const monthName = arabicMonths[month];
const todayDay = now.getDate();
---

<section class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
  <div class="bg-primary-600 text-white px-5 py-4">
    <h2 class="text-lg font-bold">
      جدول مواقيت الصلاة — {cityNameAr}
    </h2>
    <p class="text-primary-200 text-sm mt-1">
      {monthName} {year} (كامل الشهر)
    </p>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 text-gray-600 border-b border-gray-200">
          <th class="py-2 px-3 text-center font-medium">اليوم</th>
          <th class="py-2 px-3 text-center font-medium text-indigo-600">الفجر</th>
          <th class="py-2 px-3 text-center font-medium text-orange-500">الشروق</th>
          <th class="py-2 px-3 text-center font-medium text-yellow-600">الظهر</th>
          <th class="py-2 px-3 text-center font-medium text-amber-600">العصر</th>
          <th class="py-2 px-3 text-center font-medium text-primary-600 font-bold">المغرب</th>
          <th class="py-2 px-3 text-center font-medium text-slate-700">العشاء</th>
        </tr>
      </thead>
      <tbody>
        {schedule.map(row => (
          <tr
            class={`border-b border-gray-100 transition-colors ${
              row.day === todayDay
                ? 'bg-primary-50 font-semibold ring-1 ring-inset ring-primary-300'
                : 'hover:bg-gray-50'
            }`}
          >
            <td class="py-2 px-3 text-center">
              <span class={`inline-block w-7 h-7 rounded-full text-center leading-7 text-xs ${
                row.day === todayDay
                  ? 'bg-primary-600 text-white font-bold'
                  : 'text-gray-600'
              }`}>
                {row.day}
              </span>
            </td>
            <td class="py-2 px-3 text-center text-gray-700 font-mono text-xs">{row.fajr}</td>
            <td class="py-2 px-3 text-center text-gray-500 font-mono text-xs">{row.sunrise}</td>
            <td class="py-2 px-3 text-center text-gray-700 font-mono text-xs">{row.dhuhr}</td>
            <td class="py-2 px-3 text-center text-gray-700 font-mono text-xs">{row.asr}</td>
            <td class="py-2 px-3 text-center font-mono text-xs">
              <span class={`font-bold ${row.day === todayDay ? 'text-primary-700' : 'text-primary-600'}`}>
                {row.maghrib}
              </span>
            </td>
            <td class="py-2 px-3 text-center text-gray-700 font-mono text-xs">{row.isha}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <div class="px-4 py-3 bg-gray-50 text-xs text-gray-400 text-center">
    طريقة الحساب: رابطة العالم الإسلامي · التوقيت: +4 GMT
  </div>
</section>
