---
import Base from '../layouts/Base.astro';
import PrayerWidget from '../components/PrayerWidget.astro';
import MonthlyTable from '../components/MonthlyTable.astro';
import CityGrid from '../components/CityGrid.astro';
import QiblaWidget from '../components/QiblaWidget.astro';
import FAQ from '../components/FAQ.astro';
import { cities, getCityById } from '../data/cities';
import { calcPrayerTimes, formatTimeAr, arabicMonths } from '../utils/prayer';

export async function getStaticPaths() {
  return cities.map(city => ({ params: { city: city.id } }));
}

const { city: cityId } = Astro.params;
const city = getCityById(cityId as string);

if (!city) return Astro.redirect('/');

const now = new Date();
const todayTimes = calcPrayerTimes(city.lat, city.lng, now);
const monthName = arabicMonths[now.getMonth() + 1];
const arabicDays = ['الأحد','الاثنين','الثلاثاء','الأربعاء','الخميس','الجمعة','السبت'];
const dayName = arabicDays[now.getDay()];

// SEO: optimised title targeting "موعد اذان المغرب في [city]"
const title = `موعد اذان المغرب في ${city.nameAr} اليوم ${now.getDate()} ${monthName} | مواقيت الصلاة`;
const description = `موعد اذان المغرب في ${city.nameAr} اليوم ${dayName} ${now.getDate()} ${monthName} ${now.getFullYear()}: المغرب ${formatTimeAr(todayTimes.maghrib)} · الفجر ${formatTimeAr(todayTimes.fajr)} · الظهر ${formatTimeAr(todayTimes.dhuhr)} · العصر ${formatTimeAr(todayTimes.asr)} · العشاء ${formatTimeAr(todayTimes.isha)}. جدول مواقيت الصلاة الشهري في ${city.nameAr}.`;

// BreadcrumbList schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "مواقيت الصلاة",
      "item": "https://mawaqit-uae.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": `مواقيت الصلاة في ${city.nameAr}`,
      "item": `https://mawaqit-uae.com/${city.id}`
    }
  ]
};

// Speakable schema (helps with voice search)
const speakableSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `موعد اذان المغرب في ${city.nameAr} اليوم`,
  "description": description,
  "url": `https://mawaqit-uae.com/${city.id}`,
  "inLanguage": "ar",
  "dateModified": now.toISOString(),
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["#maghrib-time", "#today-date", "#next-prayer-banner"]
  }
};

// FAQ items per city
const faqItems = [
  {
    q: `ما هو موعد اذان المغرب في ${city.nameAr} اليوم؟`,
    a: `موعد أذان المغرب في ${city.nameAr} اليوم ${dayName} ${now.getDate()} ${monthName} ${now.getFullYear()} هو ${formatTimeAr(todayTimes.maghrib)}. يتغير الموعد يومياً بضع دقائق بحسب غروب الشمس.`,
  },
  {
    q: `متى موعد اذان الفجر في ${city.nameAr} اليوم؟`,
    a: `موعد أذان الفجر في ${city.nameAr} اليوم هو ${formatTimeAr(todayTimes.fajr)}.`,
  },
  {
    q: `ما هي مواقيت الصلاة الخمس في ${city.nameAr} اليوم؟`,
    a: `مواقيت الصلاة في ${city.nameAr} اليوم: الفجر ${formatTimeAr(todayTimes.fajr)}، الشروق ${formatTimeAr(todayTimes.sunrise)}، الظهر ${formatTimeAr(todayTimes.dhuhr)}، العصر ${formatTimeAr(todayTimes.asr)}، المغرب ${formatTimeAr(todayTimes.maghrib)}، العشاء ${formatTimeAr(todayTimes.isha)}.`,
  },
  {
    q: `هل أوقات الصلاة في ${city.nameAr} تختلف عن دبي؟`,
    a: `نعم، تختلف مواقيت الصلاة بين مدن الإمارات بفارق دقيقة إلى دقيقتين بحسب الموقع الجغرافي لكل مدينة. ${city.nameAr} تقع على إحداثيات ${city.lat.toFixed(2)}° شمالاً و${city.lng.toFixed(2)}° شرقاً.`,
  },
  {
    q: `كيف أتابع مواقيت الصلاة في ${city.nameAr} شهرياً؟`,
    a: `يوفر موقعنا جدولاً شهرياً كاملاً لمواقيت الصلاة في ${city.nameAr} يمكنك مراجعته في أسفل هذه الصفحة. الجدول يشمل جميع أيام الشهر الحالي.`,
  },
];

// Neighboring cities for internal linking
const neighborCities = cities
  .filter(c => c.id !== city.id)
  .sort((a, b) => {
    // Sort by distance
    const distA = Math.sqrt((a.lat - city.lat) ** 2 + (a.lng - city.lng) ** 2);
    const distB = Math.sqrt((b.lat - city.lat) ** 2 + (b.lng - city.lng) ** 2);
    return distA - distB;
  })
  .slice(0, 6);
---

<Base
  title={title}
  description={description}
  canonical={`/${city.id}`}
  cityName={city.nameAr}
  cityId={city.id}
  schema={[breadcrumbSchema, speakableSchema]}
>
  <div class="max-w-5xl mx-auto px-4 py-6">

    <!-- H1 — exact keyword match -->
    <div class="mb-5">
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight mb-1">
        موعد اذان المغرب في {city.nameAr} اليوم
      </h1>
      <p class="text-gray-500 text-sm">
        {dayName}، {now.getDate()} {monthName} {now.getFullYear()}
        · {city.descAr}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">

      <!-- Main column -->
      <div class="md:col-span-2 space-y-5">

        <!-- Prayer times widget -->
        <PrayerWidget
          cityId={city.id}
          cityNameAr={city.nameAr}
          lat={city.lat}
          lng={city.lng}
        />

        <!-- Quick times summary (static, good for SEO/bots) -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <h2 class="font-bold text-gray-800 mb-4 flex items-center gap-2">
            <span>🕌</span> مواقيت الصلاة في {city.nameAr} — {dayName} {now.getDate()} {monthName}
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 text-center text-sm">
            {[
              { label: 'الفجر',   time: formatTimeAr(todayTimes.fajr),    icon: '🌙', color: 'text-indigo-700' },
              { label: 'الشروق',  time: formatTimeAr(todayTimes.sunrise),  icon: '🌅', color: 'text-orange-500' },
              { label: 'الظهر',   time: formatTimeAr(todayTimes.dhuhr),   icon: '☀️', color: 'text-yellow-600' },
              { label: 'العصر',   time: formatTimeAr(todayTimes.asr),     icon: '🌤️', color: 'text-amber-600' },
              { label: 'المغرب',  time: formatTimeAr(todayTimes.maghrib), icon: '🌇', color: 'text-primary-700', bold: true },
              { label: 'العشاء',  time: formatTimeAr(todayTimes.isha),    icon: '🌃', color: 'text-slate-700' },
            ].map(p => (
              <div class={`p-3 rounded-lg border ${p.bold ? 'border-primary-300 bg-primary-50' : 'border-gray-100 bg-gray-50'}`}>
                <div class="text-xl">{p.icon}</div>
                <div class="text-xs text-gray-500 mt-1">{p.label}</div>
                <div class={`font-bold text-base mt-0.5 ${p.color}`}>{p.time}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Monthly table -->
        <MonthlyTable lat={city.lat} lng={city.lng} cityNameAr={city.nameAr} />

        <!-- Qibla -->
        <QiblaWidget lat={city.lat} lng={city.lng} cityNameAr={city.nameAr} />

        <!-- Article content -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <h2 class="text-lg font-bold text-gray-800 mb-3">
            مواقيت الصلاة في {city.nameAr}
          </h2>
          <div class="text-sm text-gray-700 space-y-3 leading-relaxed">
            <p>
              تقع <strong>{city.nameAr}</strong> ({city.nameEn}) في إمارة {city.descAr.split('،')[1]},
              الإمارات العربية المتحدة، على إحداثيات {city.lat.toFixed(4)}° شمالاً
              و{city.lng.toFixed(4)}° شرقاً. يتحدد موعد الصلاة بناءً على هذه الإحداثيات الدقيقة.
            </p>
            <p>
              <strong>موعد أذان المغرب</strong> في {city.nameAr} اليوم هو
              <strong class="text-primary-700"> {formatTimeAr(todayTimes.maghrib)}</strong>،
              ويبدأ وقت المغرب فور غروب الشمس وينتهي بدخول وقت صلاة العشاء
              ({formatTimeAr(todayTimes.isha)}).
            </p>
            <p>
              تعتمد الإمارات العربية المتحدة طريقة حساب <strong>رابطة العالم الإسلامي</strong>
              بزاوية فجر 18 درجة وزاوية عشاء 17 درجة، وهي الطريقة الرسمية المعتمدة من
              الهيئة العامة للشؤون الإسلامية والأوقاف (أوقاف).
            </p>
          </div>
        </div>

        <!-- FAQ -->
        <FAQ items={faqItems} cityNameAr={city.nameAr} />
      </div>

      <!-- Sidebar -->
      <div class="space-y-4">

        <!-- Nearby cities -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
          <h3 class="font-bold text-gray-700 mb-3 text-sm">مدن قريبة</h3>
          <div class="space-y-1">
            {neighborCities.map(nc => (
              <a
                href={`/${nc.id}`}
                class="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-primary-50 transition-colors text-sm group"
              >
                <span class="text-gray-700 group-hover:text-primary-700">{nc.nameAr}</span>
                <span class="text-xs text-gray-400 group-hover:text-primary-500">›</span>
              </a>
            ))}
          </div>
        </div>

        <!-- All cities grid -->
        <CityGrid currentCityId={city.id} />

        <!-- Quick links -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
          <h3 class="font-bold text-gray-700 mb-3 text-sm">روابط ذات صلة</h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="/maghrib" class="flex items-center gap-2 text-primary-600 hover:underline">
                <span>🌇</span> موعد أذان المغرب
              </a>
            </li>
            <li>
              <a href="/ramadan" class="flex items-center gap-2 text-primary-600 hover:underline">
                <span>🌙</span> مواقيت رمضان
              </a>
            </li>
            <li>
              <a href="/" class="flex items-center gap-2 text-gray-500 hover:text-primary-600">
                <span>🏠</span> الصفحة الرئيسية
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Base>
