---
import Base from '../layouts/Base.astro';
import CityGrid from '../components/CityGrid.astro';
import FAQ from '../components/FAQ.astro';
import { getCityById } from '../data/cities';
import { calcPrayerTimes, formatTimeAr, arabicMonths, getMonthSchedule } from '../utils/prayer';

// Ramadan 2025 starts March 1, 2025 (approximate, actual varies by moon sighting)
// For SEO, show current month schedule for Dubai
const now = new Date();
const dubaiCity = getCityById('dubai')!;
const dubaiTimes = calcPrayerTimes(dubaiCity.lat, dubaiCity.lng, now);

// Get Ramadan schedule (March 2025 = approximately Ramadan)
const ramadanYear = 2025;
const ramadanMonth = 3; // March 2025
const ramadanSchedule = getMonthSchedule(dubaiCity.lat, dubaiCity.lng, ramadanYear, ramadanMonth);

const title = `مواقيت الصلاة في رمضان 2025 الإمارات | أوقات السحور والإفطار`;
const description = `جدول مواقيت الصلاة في رمضان 2025 في الإمارات — دبي، أبوظبي، الشارقة. أوقات الإفطار (المغرب) والسحور (الفجر) يومياً طوال شهر رمضان المبارك.`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://mawaqit-uae.com/" },
    { "@type": "ListItem", "position": 2, "name": "رمضان 2025", "item": "https://mawaqit-uae.com/ramadan" },
  ]
};

const faqItems = [
  {
    q: 'متى موعد الإفطار في رمضان 2025 في دبي؟',
    a: 'موعد الإفطار في رمضان يتحدد بموعد أذان المغرب كل يوم. في مارس 2025 يتراوح وقت المغرب في دبي بين 6:20 م و6:30 م تقريباً.',
  },
  {
    q: 'ما هو وقت السحور في رمضان في الإمارات؟',
    a: 'ينتهي وقت السحور بأذان الفجر. يُستحب أخذ آخر السحور قبل أذان الفجر بدقائق. في رمضان 2025 في الإمارات يكون الفجر في حدود الساعة 5:10 ص تقريباً.',
  },
  {
    q: 'هل مواقيت رمضان تختلف بين مدن الإمارات؟',
    a: 'نعم، تختلف بفارق دقيقة إلى دقيقتين بين المدن. يمكنك اختيار مدينتك من القائمة للحصول على الأوقات الدقيقة.',
  },
];
---

<Base
  title={title}
  description={description}
  canonical="/ramadan"
  schema={breadcrumbSchema}
>
  <div class="max-w-5xl mx-auto px-4 py-6">

    <!-- Hero -->
    <div class="bg-gradient-to-br from-primary-800 to-primary-600 text-white rounded-2xl p-6 mb-6 text-center">
      <div class="text-4xl mb-2">🌙</div>
      <h1 class="text-2xl md:text-3xl font-bold mb-2">
        مواقيت الصلاة في رمضان 2025
      </h1>
      <p class="text-primary-200 text-sm">
        الإمارات العربية المتحدة · جدول كامل للسحور والإفطار
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="md:col-span-2 space-y-5">

        <!-- Today's iftar/suhoor -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-primary-600 text-white rounded-2xl p-4 text-center">
            <div class="text-2xl mb-1">🍽️</div>
            <div class="text-xs text-primary-200 mb-1">وقت الإفطار (المغرب)</div>
            <div class="text-2xl font-bold">{formatTimeAr(dubaiTimes.maghrib)}</div>
            <div class="text-xs text-primary-300 mt-1">دبي — اليوم</div>
          </div>
          <div class="bg-indigo-700 text-white rounded-2xl p-4 text-center">
            <div class="text-2xl mb-1">🌙</div>
            <div class="text-xs text-indigo-200 mb-1">وقت السحور (الفجر)</div>
            <div class="text-2xl font-bold">{formatTimeAr(dubaiTimes.fajr)}</div>
            <div class="text-xs text-indigo-300 mt-1">دبي — اليوم</div>
          </div>
        </div>

        <!-- Ramadan schedule table -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="bg-primary-600 text-white px-5 py-4">
            <h2 class="font-bold text-lg">جدول مواقيت رمضان 2025 — دبي</h2>
            <p class="text-primary-200 text-sm mt-1">شهر مارس 2025 (موعد رمضان التقريبي)</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50 text-gray-600 border-b">
                  <th class="py-2 px-3 text-center">اليوم</th>
                  <th class="py-2 px-3 text-center text-indigo-700 font-bold">السحور (الفجر)</th>
                  <th class="py-2 px-3 text-center text-yellow-600">الظهر</th>
                  <th class="py-2 px-3 text-center text-amber-600">العصر</th>
                  <th class="py-2 px-3 text-center text-primary-700 font-bold">الإفطار (المغرب)</th>
                  <th class="py-2 px-3 text-center">العشاء</th>
                </tr>
              </thead>
              <tbody>
                {ramadanSchedule.map(row => (
                  <tr class="border-b border-gray-100 hover:bg-gray-50">
                    <td class="py-2 px-3 text-center text-xs text-gray-600">{row.day} مارس</td>
                    <td class="py-2 px-3 text-center font-mono text-xs text-indigo-700 font-semibold">{row.fajr}</td>
                    <td class="py-2 px-3 text-center font-mono text-xs text-gray-600">{row.dhuhr}</td>
                    <td class="py-2 px-3 text-center font-mono text-xs text-gray-600">{row.asr}</td>
                    <td class="py-2 px-3 text-center font-mono text-xs text-primary-700 font-bold">{row.maghrib}</td>
                    <td class="py-2 px-3 text-center font-mono text-xs text-gray-600">{row.isha}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Article content -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <h2 class="text-lg font-bold text-gray-800 mb-4">رمضان في الإمارات — أوقات الصيام</h2>
          <div class="space-y-3 text-sm text-gray-700 leading-relaxed">
            <p>
              يبدأ شهر <strong>رمضان المبارك</strong> بثبوت هلال الشهر الكريم.
              تُعلن دائرة الشؤون الإسلامية في الإمارات عن بداية الشهر رسمياً بناءً على رؤية
              الهلال أو الحساب الفلكي.
            </p>
            <p>
              <strong>وقت الإفطار</strong> هو موعد أذان المغرب تماماً، ويُسن للصائم
              التعجيل بالفطر عند سماع الأذان. <strong>وقت السحور</strong> ينتهي بأذان الفجر،
              ويُستحب الأكل حتى آخر لحظة قبل الأذان.
            </p>
            <p>
              تتوفر في الإمارات خدمات متعددة خلال رمضان لإعلان مواقيت الصلاة، منها:
              المساجد، التطبيقات الرسمية، ومنصة أوقاف الإمارات.
            </p>
          </div>
        </div>

        <FAQ items={faqItems} />
      </div>

      <div class="space-y-4">
        <CityGrid />
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
          <h3 class="font-bold text-gray-700 mb-3 text-sm">روابط سريعة</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/maghrib" class="text-primary-600 hover:underline flex gap-2"><span>🌇</span>موعد أذان المغرب</a></li>
            <li><a href="/dubai" class="text-gray-600 hover:text-primary-600 flex gap-2"><span>🕌</span>مواقيت دبي</a></li>
            <li><a href="/abu-dhabi" class="text-gray-600 hover:text-primary-600 flex gap-2"><span>🕌</span>مواقيت أبوظبي</a></li>
            <li><a href="/" class="text-gray-500 hover:text-primary-600 flex gap-2"><span>🏠</span>الرئيسية</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Base>
