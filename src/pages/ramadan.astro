---
import Base from '../layouts/Base.astro';
import CityGrid from '../components/CityGrid.astro';
import FAQ from '../components/FAQ.astro';
import { getCityById } from '../data/cities';
import { calcPrayerTimes, formatTimeAr, arabicMonths, getMonthSchedule } from '../utils/prayer';
import { u } from '../utils/url';

const now = new Date();
const dubaiCity = getCityById('dubai')!;
const dubaiTimes = calcPrayerTimes(dubaiCity.lat, dubaiCity.lng, now);

// Ramadan 2025: March 1 – March 30 (approximate)
const ramadanSchedule = getMonthSchedule(dubaiCity.lat, dubaiCity.lng, 2025, 3);

const title = `مواقيت الصلاة في رمضان 2025 الإمارات | أوقات السحور والإفطار`;
const description = `جدول مواقيت الصلاة في رمضان 2025 في الإمارات — دبي، أبوظبي، الشارقة. أوقات الإفطار (المغرب) والسحور (الفجر) يومياً طوال شهر رمضان المبارك.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'الرئيسية', item: 'https://franruiloz-lab.github.io/mawaqit-uae/' },
    { '@type': 'ListItem', position: 2, name: 'رمضان 2025', item: 'https://franruiloz-lab.github.io/mawaqit-uae/ramadan' },
  ],
};

const faqItems = [
  {
    q: 'متى موعد الإفطار في رمضان 2025 في دبي؟',
    a: 'موعد الإفطار في رمضان يتحدد بموعد أذان المغرب كل يوم. في مارس 2025 يتراوح وقت المغرب في دبي بين 6:20 م و6:30 م تقريباً.',
  },
  {
    q: 'ما هو وقت السحور في رمضان في الإمارات؟',
    a: 'ينتهي وقت السحور بأذان الفجر. في رمضان 2025 في الإمارات يكون الفجر في حدود الساعة 5:10 ص تقريباً.',
  },
  {
    q: 'هل مواقيت رمضان تختلف بين مدن الإمارات؟',
    a: 'نعم، تختلف بفارق دقيقة إلى دقيقتين. اختر مدينتك من القائمة للحصول على الأوقات الدقيقة.',
  },
  {
    q: 'ما هو أول يوم رمضان 2025؟',
    a: 'وفق التقديرات الفلكية، يبدأ رمضان 2025 في أوائل مارس (حوالي 1-3 مارس 2025). ويُعلن رسمياً بعد رؤية الهلال.',
  },
];
---

<Base
  title={title}
  description={description}
  canonical="/ramadan"
  cityId="ramadan"
  cityName="رمضان 2025"
  schema={breadcrumbSchema}
>
  <div class="max-w-5xl mx-auto px-4 py-6">

    <!-- Hero -->
    <div class="bg-gradient-to-br from-primary-800 to-primary-600 text-white rounded-2xl p-6 mb-6 text-center">
      <div class="text-4xl mb-2">🌙</div>
      <h1 class="text-2xl md:text-3xl font-bold mb-2">مواقيت الصلاة في رمضان 2025</h1>
      <p class="text-primary-200 text-sm">الإمارات العربية المتحدة · جدول كامل للسحور والإفطار</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="md:col-span-2 space-y-5">

        <!-- Today iftar/suhoor -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-primary-600 text-white rounded-2xl p-4 text-center">
            <div class="text-2xl mb-1">🍽️</div>
            <div class="text-xs text-primary-200 mb-1">وقت الإفطار (المغرب)</div>
            <div class="text-2xl font-bold">{formatTimeAr(dubaiTimes.maghrib)}</div>
            <div class="text-xs text-primary-300 mt-1">دبي — اليوم</div>
          </div>
          <div class="bg-indigo-700 text-white rounded-2xl p-4 text-center">
            <div class="text-2xl mb-1">🌙</div>
            <div class="text-xs text-indigo-200 mb-1">وقت السحور (الفجر)</div>
            <div class="text-2xl font-bold">{formatTimeAr(dubaiTimes.fajr)}</div>
            <div class="text-xs text-indigo-300 mt-1">دبي — اليوم</div>
          </div>
        </div>

        <!-- City quick links -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
          <h2 class="font-bold text-gray-800 mb-3 text-sm">مواقيت رمضان حسب المدينة</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
            {['dubai','abu-dhabi','sharjah','ajman','al-ain','ras-al-khaimah','fujairah','umm-al-quwain'].map(id => {
              const c = getCityById(id)!;
              return (
                <a
                  href={u(c.id)}
                  class="flex flex-col items-center p-2 rounded-lg border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors text-center text-xs"
                >
                  <span class="text-lg">🕌</span>
                  <span class="font-medium text-gray-700 mt-0.5">{c.nameAr}</span>
                </a>
              );
            })}
          </div>
        </div>

        <!-- Ramadan schedule table -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="bg-primary-600 text-white px-5 py-4">
            <h2 class="font-bold text-lg">جدول مواقيت رمضان 2025 — دبي</h2>
            <p class="text-primary-200 text-sm mt-1">شهر مارس 2025 (موعد رمضان التقريبي)</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50 text-gray-600 border-b">
                  <th class="py-2 px-3 text-center font-medium">اليوم</th>
                  <th class="py-2 px-3 text-center font-medium text-indigo-700">السحور (الفجر)</th>
                  <th class="py-2 px-3 text-center font-medium text-yellow-600">الظهر</th>
                  <th class="py-2 px-3 text-center font-medium text-amber-600">العصر</th>
                  <th class="py-2 px-3 text-center font-medium text-primary-700">الإفطار (المغرب)</th>
                  <th class="py-2 px-3 text-center font-medium">العشاء</th>
                </tr>
              </thead>
              <tbody>
                {ramadanSchedule.map(row => (
                  <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                    <td class="py-2 px-3 text-center text-xs text-gray-600">{row.day} مارس</td>
                    <td class="py-2 px-3 text-center font-mono text-xs text-indigo-700 font-semibold">{row.fajr}</td>
                    <td class="py-2 px-3 text-center font-mono text-xs text-gray-600">{row.dhuhr}</td>
                    <td class="py-2 px-3 text-center font-mono text-xs text-gray-600">{row.asr}</td>
                    <td class="py-2 px-3 text-center font-mono text-xs text-primary-700 font-bold">{row.maghrib}</td>
                    <td class="py-2 px-3 text-center font-mono text-xs text-gray-600">{row.isha}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Article -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <h2 class="text-lg font-bold text-gray-800 mb-4">رمضان في الإمارات — أوقات الصيام</h2>
          <div class="space-y-3 text-sm text-gray-700 leading-relaxed">
            <p>
              يبدأ شهر <strong>رمضان المبارك</strong> بثبوت هلال الشهر الكريم.
              تُعلن دائرة الشؤون الإسلامية في الإمارات عن بداية الشهر رسمياً بناءً على رؤية الهلال.
            </p>
            <p>
              <strong>وقت الإفطار</strong> هو موعد أذان المغرب تماماً. يُسن التعجيل بالفطر.
              <strong>وقت السحور</strong> ينتهي بأذان الفجر، ويُستحب الأكل حتى آخر لحظة.
            </p>
            <p>
              لمعرفة مواقيت الصلاة اليومية في مدينتك، اختر من القائمة أعلاه.
              أو زر <a href={u('maghrib')} class="text-primary-600 hover:underline">صفحة أذان المغرب</a>
              لأوقات المغرب اليومية في جميع المدن.
            </p>
          </div>
        </div>

        <FAQ items={faqItems} />
      </div>

      <div class="space-y-4">
        <CityGrid />
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
          <h3 class="font-bold text-gray-700 mb-3 text-sm">روابط سريعة</h3>
          <ul class="space-y-1 text-sm">
            <li>
              <a href={u('maghrib')} class="flex items-center gap-2 py-2 px-2 rounded-lg text-primary-600 hover:bg-primary-50 transition-colors">
                <span>🌇</span> موعد أذان المغرب
              </a>
            </li>
            <li>
              <a href={u('dubai')} class="flex items-center gap-2 py-2 px-2 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">
                <span>🕌</span> مواقيت دبي
              </a>
            </li>
            <li>
              <a href={u('abu-dhabi')} class="flex items-center gap-2 py-2 px-2 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">
                <span>🕌</span> مواقيت أبوظبي
              </a>
            </li>
            <li>
              <a href={u('')} class="flex items-center gap-2 py-2 px-2 rounded-lg text-gray-500 hover:bg-gray-50 transition-colors">
                <span>🏠</span> الرئيسية
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Base>
