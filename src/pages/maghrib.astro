---
import Base from '../layouts/Base.astro';
import PrayerWidget from '../components/PrayerWidget.astro';
import CityGrid from '../components/CityGrid.astro';
import FAQ from '../components/FAQ.astro';
import { getCityById, cities } from '../data/cities';
import { calcPrayerTimes, formatTimeAr, arabicMonths } from '../utils/prayer';
import { u } from '../utils/url';

const now = new Date();
const arabicDays = ['الأحد','الاثنين','الثلاثاء','الأربعاء','الخميس','الجمعة','السبت'];
const dayName = arabicDays[now.getDay()];
const monthName = arabicMonths[now.getMonth() + 1];

const majorCityIds = ['dubai','abu-dhabi','sharjah','ajman','al-ain','ras-al-khaimah','fujairah','umm-al-quwain'];
const cityMaghrib = majorCityIds.map(id => {
  const c = getCityById(id)!;
  return { city: c, maghrib: formatTimeAr(calcPrayerTimes(c.lat, c.lng, now).maghrib) };
});

const dubaiCity = getCityById('dubai')!;
const dubaiTimes = calcPrayerTimes(dubaiCity.lat, dubaiCity.lng, now);

const title = `موعد اذان المغرب اليوم في الإمارات | ${dayName} ${now.getDate()} ${monthName} ${now.getFullYear()}`;
const description = `موعد اذان المغرب اليوم في جميع مدن الإمارات — دبي ${formatTimeAr(dubaiTimes.maghrib)} · أبوظبي · الشارقة · عجمان · رأس الخيمة. تحديث يومي دقيق.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'الرئيسية', item: import.meta.env.SITE },
    { '@type': 'ListItem', position: 2, name: 'موعد أذان المغرب', item: `${import.meta.env.SITE}maghrib` },
  ],
};

const faqItems = [
  {
    q: 'ما هو موعد اذان المغرب اليوم في دبي؟',
    a: `موعد أذان المغرب في دبي اليوم ${dayName} ${now.getDate()} ${monthName} هو ${formatTimeAr(dubaiTimes.maghrib)}.`,
  },
  {
    q: 'لماذا يختلف موعد المغرب بين مدن الإمارات؟',
    a: 'يختلف موعد المغرب بحسب خط الطول الجغرافي. المدن الشرقية (كالفجيرة) تشهد الغروب قبل المدن الغربية (كأبوظبي) بعدة دقائق.',
  },
  {
    q: 'كم مدة وقت صلاة المغرب؟',
    a: 'يبدأ وقت المغرب من غروب الشمس وينتهي باختفاء الشفق الأحمر، ما يعادل تقريباً ساعة إلى ساعة ونصف بعد الأذان.',
  },
  {
    q: 'هل يتغير موعد المغرب في رمضان؟',
    a: 'يتغير موعد المغرب يومياً بغض النظر عن رمضان، إذ يتحدد دائماً بموعد غروب الشمس. في رمضان يكون المغرب هو وقت الإفطار.',
  },
  {
    q: 'ما طريقة حساب موعد المغرب في الإمارات؟',
    a: 'أما المغرب فيُحسب بغروب الشمس مباشرة (0.833 درجة تحت الأفق) بدون اعتبار لزوايا خاصة.',
  },
];
---

<Base
  title={title}
  description={description}
  canonical="/maghrib"
  cityId="maghrib"
  cityName="موعد أذان المغرب"
  schema={breadcrumbSchema}
>
  <div class="max-w-5xl mx-auto px-4 py-6">

    <div class="mb-5">
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight mb-1">
        موعد اذان المغرب اليوم في الإمارات
      </h1>
      <p class="text-gray-500 text-sm">
        {dayName}، {now.getDate()} {monthName} {now.getFullYear()} · تحديث يومي تلقائي
      </p>
    </div>

    <!-- All cities Maghrib times -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
      <div class="bg-gradient-to-l from-primary-600 to-primary-800 text-white px-5 py-4">
        <h2 class="font-bold text-lg">🌇 موعد المغرب اليوم في جميع المدن</h2>
        <p class="text-primary-200 text-sm mt-1">{dayName} {now.getDate()} {monthName} {now.getFullYear()}</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4">
        {cityMaghrib.map(({ city, maghrib }) => (
          <a
            href={u(city.id)}
            class="flex flex-col items-center p-4 border-b border-l border-gray-100 hover:bg-primary-50 transition-colors group active:bg-primary-100"
          >
            <div class="text-xs text-gray-500 mb-1 group-hover:text-primary-600 transition-colors">{city.nameAr}</div>
            <div class="text-2xl font-bold text-primary-700 group-hover:text-primary-900">{maghrib}</div>
            <div class="text-xs text-gray-400 mt-1 group-hover:text-primary-500">تفاصيل ›</div>
          </a>
        ))}
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="md:col-span-2 space-y-5">

        <!-- Dubai widget as default -->
        <PrayerWidget
          cityId={dubaiCity.id}
          cityNameAr={dubaiCity.nameAr}
          lat={dubaiCity.lat}
          lng={dubaiCity.lng}
        />

        <!-- Article -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <h2 class="text-lg font-bold text-gray-800 mb-4">صلاة المغرب — وقتها وأحكامها</h2>
          <div class="space-y-4 text-sm text-gray-700 leading-relaxed">
            <div>
              <h3 class="font-bold text-gray-800 mb-1">⏰ وقت صلاة المغرب</h3>
              <p>
                يبدأ وقت صلاة المغرب بغروب الشمس، أي لحظة اختفاء القرص الشمسي عن الأفق.
                وينتهي وقتها باختفاء الشفق الأحمر من الأفق الغربي (نحو ساعة إلى ساعة ونصف).
              </p>
            </div>
            <div>
              <h3 class="font-bold text-gray-800 mb-1">🕌 ركعاتها وسننها</h3>
              <p>
                صلاة المغرب ثلاث ركعات مفروضة، وتُصلّى ركعتان نافلة بعدها.
                يُستحب التبكير بها فور سماع الأذان.
              </p>
            </div>
            <div>
              <h3 class="font-bold text-gray-800 mb-1">🌙 المغرب في رمضان</h3>
              <p>
                في رمضان يكون أذان المغرب إشارة الإفطار. تجد في صفحة
                <a href={u('ramadan')} class="text-primary-600 hover:underline">مواقيت رمضان</a>
                جدولاً كاملاً لشهر رمضان.
              </p>
            </div>
            <div>
              <h3 class="font-bold text-gray-800 mb-1">📍 كيف يُحسب وقت المغرب في الإمارات؟</h3>
              <p>
                تعتمد الهيئة العامة للشؤون الإسلامية والأوقاف طريقة علمية دقيقة تعتمد
                على الإحداثيات الجغرافية لكل مدينة وزاوية ميل الشمس.
              </p>
            </div>
          </div>
        </div>

        <FAQ items={faqItems} />
      </div>

      <div class="space-y-4">
        <CityGrid />
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
          <h3 class="font-bold text-gray-700 mb-3 text-sm">روابط سريعة</h3>
          <ul class="space-y-1 text-sm">
            <li>
              <a href={u('ramadan')} class="flex items-center gap-2 py-2 px-2 rounded-lg text-primary-600 hover:bg-primary-50 transition-colors">
                <span>🌙</span> مواقيت رمضان
              </a>
            </li>
            <li>
              <a href={u('dubai')} class="flex items-center gap-2 py-2 px-2 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">
                <span>🕌</span> مواقيت الصلاة دبي
              </a>
            </li>
            <li>
              <a href={u('')} class="flex items-center gap-2 py-2 px-2 rounded-lg text-gray-500 hover:bg-gray-50 transition-colors">
                <span>🏠</span> الصفحة الرئيسية
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Base>
